# Скопируй в .env и заполни.
# Ключ читает ТОЛЬКО сервер — в браузер он не попадает.

# API-ключ BytePlus ModelArk (или fal.ai, если provider=fal в config.json)
SEEDANCE_API_KEY=

# Порт локального сервера
PORT=5178

# MOCK=1 — работать без ключа: UI отдаёт демо-видео, реальные вызовы API не идут.
# Поставь MOCK=0 (или убери строку), когда впишешь рабочий ключ.
MOCK=1

# BytePlus TOS — авто-заливка видео/аудио-рефов (Ark не принимает их base64, только URL).
# Создай bucket в консоли TOS, возьми его endpoint/region; AccessKey/Secret — в BytePlus IAM.
# Можно оставить пустым: тогда видео/аудио только по публичному URL.
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_REGION=ap-southeast-1
TOS_ENDPOINT=tos-ap-southeast-1.bytepluses.com
TOS_BUCKET=
TOS_PRESIGN_EXPIRES=7200
